generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id              String   @id @default(cuid())
  razaoSocial     String
  cnpj            String   @unique
  enderecoJson    Json?
  logoUrl         String?
  contextoEmpresa String?
  perfilRitmo     String?
  valores         String[]
  createdAt       DateTime @default(now())

  users              User[]
  jobs               Job[]
  candidates         Candidate[]
  personalityResults PersonalityResult[]
  chatMessages       ChatMessage[]
  testLinks          TestLink[]
}

model User {
  id            String    @id @default(cuid())
  companyId     String?
  nome          String?
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("recruiter")
  createdAt     DateTime  @default(now())

  company  Company?  @relation(fields: [companyId], references: [id])
  accounts Account[]
  sessions Session[]
}

model Job {
  id                String   @id @default(cuid())
  companyId         String
  titulo            String
  motivo            String?
  descricao         String?
  responsabilidades String?
  metas             String?
  jdGerada          String?
  salaryMin         Float?
  salaryMax         Float?
  perfilIdealJson   Json?
  status            String   @default("active")
  createdAt         DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id])
  candidates   Candidate[]
  matchReports MatchReport[]
  chatMessages ChatMessage[]
}

model Candidate {
  id              String    @id @default(cuid())
  jobId           String
  companyId       String
  nome            String
  email           String
  linkedinUrl     String?
  cvUrl           String?
  respostasJson   Json?
  entrevistaTexto String?
  testLinkToken   String?   @unique
  testCompletedAt DateTime?
  createdAt       DateTime  @default(now())

  job                Job                 @relation(fields: [jobId], references: [id])
  company            Company             @relation(fields: [companyId], references: [id])
  personalityResults PersonalityResult[]
  matchReports       MatchReport[]
  testLinks          TestLink[]
}

model PersonalityResult {
  id            String   @id @default(cuid())
  companyId     String
  subjectId     String
  subjectType   String
  discJson      Json?
  enneagramJson Json?
  mbtiJson      Json?
  createdAt     DateTime @default(now())

  company   Company    @relation(fields: [companyId], references: [id])
  candidate Candidate? @relation(fields: [subjectId], references: [id])
}

model MatchReport {
  id              String   @id @default(cuid())
  jobId           String
  candidateId     String
  rankingPosition Int?
  matchScore      Float?
  relatorioJson   Json?
  createdAt       DateTime @default(now())

  job       Job       @relation(fields: [jobId], references: [id])
  candidate Candidate @relation(fields: [candidateId], references: [id])
}

model ChatMessage {
  id        String   @id @default(cuid())
  companyId String
  jobId     String?
  role      String
  content   String
  createdAt DateTime @default(now())

  company Company  @relation(fields: [companyId], references: [id])
  job     Job?     @relation(fields: [jobId], references: [id])
}

model TestLink {
  id          String    @id @default(cuid())
  companyId   String
  token       String    @unique @default(cuid())
  candidateId String?
  expiresAt   DateTime
  completedAt DateTime?
  type        String    @default("candidate")
  createdAt   DateTime  @default(now())

  company   Company    @relation(fields: [companyId], references: [id])
  candidate Candidate? @relation(fields: [candidateId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}